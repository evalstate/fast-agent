{"version": 2, "width": 104, "height": 20, "timestamp": 1780853425, "idle_time_limit": 1.0, "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}, "title": "fast-agent A2A server card and transports"}
[7.153201, "o", "\u001b[1;36m$ uv run fast-agent serve --transport a2a --host 0.0.0.0 --port 41241 --model passthrough\u001b[0m\r\r\nfast-agent A2A server listening on http://0.0.0.0:41241\r\r\n"]
[7.154392, "o", "\u001b[1;36m$ curl -s -H \"Host: a2a.example.test:41241\" http://127.0.0.1:41241/.well-known/agent-card.json | python -m json.tool\u001b[0m\r\r\n"]
[7.183272, "o", "[\r\n  {\r\n    \"url\": \"http://a2a.example.test:41241/a2a/jsonrpc\",\r\n    \"protocolBinding\": \"JSONRPC\",\r\n    \"protocolVersion\": \"1.0\"\r\n  },\r\n  {\r\n    \"url\": \"http://a2a.example.test:41241/a2a/rest\",\r\n    \"protocolBinding\": \"HTTP+JSON\",\r\n    \"protocolVersion\": \"1.0\"\r\n  }\r\n]\r\n"]
[7.187745, "o", "\u001b[1;32mThe served card uses the hostname from the incoming card request.\u001b[0m\r\r\n"]
