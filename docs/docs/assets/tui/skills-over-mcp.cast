[5.036926, "o", "\u001b[?7727h\u001b(B\u001b[m\u001b[?12l\u001b[?25h\u001b[?1006l\u001b[?1000l\u001b[?1002l\u001b[?1003l\u001b[1;1H\u001b[1;22r\u001b[11;3H\u001b[?25l\u001b[Hbash-5.2$ uv run fast-agent -x --model passthrough\u001b[K\u001b[2m\r\nUse \u001b[32m'/'\u001b[39m for commands, \u001b[32m'!'\u001b[39m for shell. \u001b[32m'#'\u001b[39m to query, \u001b[32m'@'\u001b[39m to switch agents\u001b(B\u001b[m\u001b[K\u001b[2m\r\nCTRL+T multiline, CTRL+Y copy last message, CTRL+E external editor.\u001b(B\u001b[m\u001b[K\u001b[2m\r\nCTRL+Space or Tab for path completion. Use \u001b[35m/\u001b[95mattach\u001b[39m, `^file:`, or `^url:` for attachments. F10 to\u001b[5;1Hclear.\u001b(B\u001b[m\u001b[K\u001b[2m\r\nfast-agent environment\u001b(B\u001b[m \u001b[34m/tmp/tmp.lUDBM4Wrjc\u001b[39m\u001b[2m \u001b[1m(\u001b[36m1\u001b(B\u001b[m\u001b[2m agent, \u001b[36m\u001b[1m0\u001b(B\u001b[m\u001b[2m hooks, \u001b[36m\u001b[1m0\u001b(B\u001b[m\u001b[2m extensions, \u001b[36m\u001b[1m0\u001b(B\u001b[m\u001b[2m modelrefs\u001b[1m)\u001b(B\u001b[m\u001b[2m via \u001b(B\u001b[m\u001b[K\u001b[2m\r\nFAST_AGENT_HOME\u001b(B\u001b[m\u001b[K\u001b[33m\u001b[1m\r\nAgents have shell\u001b(B\u001b[m\u001b[2m (switch, bash | cwd: tmp/fast-agent-skills-mcp.yg2p6z)\u001b(B\u001b[m\u001b[K\u001b[2m\r\nStreaming Enabled - markdown mode\u001b(B\u001b[m\u001b[K\r\n\u001b[K\u001b[93m\r\n❯\u001b[39m\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\u001b[30m\u001b[47m\u001b[7m\r\n \u001b[34m\u001b[40m agent \u001b[30m\u001b[47m  \u001b[32m\u001b[40mT\u001b[30m\u001b[107mVD\u001b[100m ▲ \u001b[47m \u001b[42mpassthrough\u001b[47m | 0.00% | \u001b[32m\u001b[40m NRML \u001b[30m\u001b[47m | fast-agent-skills-mcp.yg2p6z | fast-agent 0.7.15\u001b(B\u001b[m\u001b[?12l\u001b[?25h\u001b[11;3H"]
