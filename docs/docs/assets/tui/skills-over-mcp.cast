[5.879687, "o", "\r\n\u001b[32m\u001b[40m mcp      \u001b[34m Manage MCP runtime servers (/mcp list|connect|disconnect|reconnect|session)         \u001b[38;5;16m\u001b[48;5;238m \u001b[13;1H\u001b[32m\u001b[40m connect  \u001b[34m Alias for /mcp connect with target auto-detection                                   \u001b[38;5;16m\u001b[48;5;238m \u001b[14;1H\u001b[32m\u001b[40m history  \u001b[34m Show conversation history overview (or /history show|detail|save|load|clear|rewi... \u001b[38;5;16m\u001b[48;5;238m \u001b[15;1H\u001b[32m\u001b[40m tools    \u001b[34m List tools                                                                          \u001b[38;5;16m\u001b[48;5;238m \u001b[16;1H\u001b[32m\u001b[40m model    \u001b[34m Inspect/switch models and update runtime settings (/model reasoning|task_budget|... \u001b[38;5;16m\u001b[48;5;238m \u001b[17;1H\u001b[32m\u001b[40m skills   \u001b[34m Manage skills (/skills, /skills available, /skills search, /skills add, /skills ... \u001b[38;5;16m\u001b[48;5;248m \u001b[18;1H\u001b[32m\u001b[40m cards    \u001b[34m Manage card packs (/cards, /cards add, /cards remove, /cards update, /cards publ... \u001b[38;5;16m\u001b[48;5;248m \u001b[19;1H\u001b[32m\u001b[40m plugins  \u001b[34m Manage command plugins (/plugins, /plugins available, /plugins add, /plugins rem... \u001b[38;5;16m\u001b[48;5;248m \u001b[20;1H\u001b[32m\u001b[40m prompt   \u001b[34m Load a Prompt File or use MCP Prompt                                                \u001b[38;5;16m\u001b[48;5;248m \u001b[21;1H\u001b[32m\u001b[40m attach   \u001b[34m Stage file path or remote URL attachment token(s) for the next prompt               \u001b[38;5;16m\u001b[48;5;248m \u001b[11;4H\u001b(B\u001b[m"]
