[5.869385, "o", "\r\n\u001b[32m\u001b[40m mcp      \u001b[34m Manage MCP runtime servers (/mcp list|connect|disconnect|reconnect)                 \u001b[38;5;16m\u001b[48;5;238m \u001b[11;1H\u001b[32m\u001b[40m connect  \u001b[34m Alias for /mcp connect with target auto-detection                                   \u001b[38;5;16m\u001b[48;5;238m \u001b[12;1H\u001b[32m\u001b[40m history  \u001b[34m Show conversation history overview (or /history show|detail|save|load|clear|rewi... \u001b[38;5;16m\u001b[48;5;238m \u001b[13;1H\u001b[32m\u001b[40m tools    \u001b[34m List tools                                                                          \u001b[38;5;16m\u001b[48;5;238m \u001b[14;1H\u001b[32m\u001b[40m model    \u001b[34m Model inspection, switching, and runtime settings (/model, /model task_budget 64... \u001b[38;5;16m\u001b[48;5;238m \u001b[15;1H\u001b[32m\u001b[40m models   \u001b[34m Model onboarding and reference diagnostics (/models, /models doctor, /models ref... \u001b[38;5;16m\u001b[48;5;238m \u001b[16;1H\u001b[32m\u001b[40m check    \u001b[34m Config diagnostics (/check, /check run)                                             \u001b[38;5;16m\u001b[48;5;238m \u001b[17;1H\u001b[32m\u001b[40m commands \u001b[34m Show command map and detailed command help                                          \u001b[38;5;16m\u001b[48;5;238m \u001b[18;1H\u001b[32m\u001b[40m skills   \u001b[34m Manage local skills (/skills, /skills available, /skills search docker, /skills ... \u001b[38;5;16m\u001b[48;5;238m \u001b[19;1H\u001b[32m\u001b[40m cards    \u001b[34m Manage card packs (/cards, /cards add <number|name>, /cards readme <number|name>... \u001b[38;5;16m\u001b[48;5;248m \u001b[20;1H\u001b[32m\u001b[40m plugins  \u001b[34m Manage command plugins (/plugins, /plugins available, /plugins add <number|name>... \u001b[38;5;16m\u001b[48;5;248m \u001b[21;1H\u001b[32m\u001b[40m prompt   \u001b[34m Load a Prompt File or use MCP Prompt                                           