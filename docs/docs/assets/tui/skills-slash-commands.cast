[6.148766, "o", "\n\u001b[32m\u001b[40m list      \u001b[34m List local skills            \u001b[38;5;16m\u001b[48;5;238m \u001b[11;11H\u001b[32m\u001b[40m available \u001b[34m Browse marketplace skills    \u001b[38;5;16m\u001b[48;5;238m \u001b[12;11H\u001b[32m\u001b[40m search    \u001b[34m Search marketplace skills    \u001b[38;5;16m\u001b[48;5;238m \u001b[13;11H\u001b[32m\u001b[40m add       \u001b[34m Install a skill              \u001b[38;5;16m\u001b[48;5;238m \u001b[14;11H\u001b[32m\u001b[40m remove    \u001b[34m Remove a local skill         \u001b[38;5;16m\u001b[48;5;238m \u001b[15;11H\u001b[32m\u001b[40m update    \u001b[34m Check or apply skill updates \u001b[38;5;16m\u001b[48;5;238m \u001b[16;11H\u001b[32m\u001b[40m registry  \u001b[34m Set the skills registry      \u001b[38;5;16m\u001b[48;5;238m \u001b[17;11H\u001b[32m\u001b[40m help      \u001b[34m Show skills command usage    \u001b[38;5;16m\u001b[48;5;238m \u001b[9;11H\u001b(B\u001b[m"]
