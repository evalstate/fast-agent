[6.307227, "o", "\n\u001b[32m\u001b[40m --registry   \u001b[34m Override the skills registry for this invocation.          \u001b[38;5;16m\u001b[48;5;238m \u001b[11;15H\u001b[32m\u001b[40m -r           \u001b[34m Override the skills registry for this invocation.          \u001b[38;5;16m\u001b[48;5;238m \u001b[12;15H\u001b[32m\u001b[40m --skills-dir \u001b[34m Override the managed skills directory for this invocation. \u001b[38;5;16m\u001b[48;5;238m \u001b[13;15H\u001b[32m\u001b[40m (empty)      \u001b[34m press Enter with no argument to pick from a list           \u001b[38;5;16m\u001b[48;5;238m \u001b[14;15H\u001b[32m\u001b[40m <number>     \u001b[34m by index — marketplace skill                               \u001b[38;5;16m\u001b[48;5;238m \u001b[15;15H\u001b[32m\u001b[40m <name>       \u001b[34m by name — marketplace skill                                \u001b[38;5;16m\u001b[48;5;238m \u001b[16;15H\u001b[32m\u001b[40m <github-url> \u001b[34m direct GitHub SKILL.md URL                                 \u001b[38;5;16m\u001b[48;5;238m \u001b[17;15H\u001b[32m\u001b[40m <path>       \u001b[34m direct local SKILL.md file or skill directory              \u001b[38;5;16m\u001b[48;5;238m \u001b[9;15H\u001b(B\u001b[m"]
