[6.533125, "o", "\u001b[2mUse \u001b[32m'/'\u001b[39m for commands, \u001b[32m'!'\u001b[39m for shell. \u001b[32m'#'\u001b[39m to query, \u001b[32m'@'\u001b[39m to switch agents\r\nCTRL+T multiline, CTRL+Y copy last message, CTRL+E external editor.\r\nCTRL+Space or Tab for path completion. Use \u001b[35m/\u001b[95mattach\u001b[39m, `^file:`, or `^url:` for attachments. F10 to\u001b[7;1Hclear.\r\n\u001b(B\u001b[m"]
[6.533184, "o", "\u001b[2mModel shortcuts:\r\n\u001b(B\u001b[m"]
[6.533418, "o", "\u001b[2m  Shift+Tab = Service tier \u001b[1m(\u001b(B\u001b[m\u001b[2mstandard, fast\u001b[1m)\r\n\u001b(B\u001b[m"]
[6.533637, "o", "\u001b[2m  F8 = Web search \u001b[1m(\u001b(B\u001b[m\u001b[2mon, off\u001b[1m)\u001b[12;1H\u001b(B\u001b[m"]
[6.534152, "o", "\u001b[2mfast-agent environment\u001b(B\u001b[m \u001b[34m~/source/fast-agent-docs-update/.fast-agent\u001b[39m\u001b[2m \u001b[1m(\u001b[36m2\u001b(B\u001b[m\u001b[2m agents, \u001b[36m\u001b[1m2\u001b(B\u001b[m\u001b[2m hooks, \u001b[36m\u001b[1m3\u001b(B\u001b[m\u001b[2m \r\nextensions, \u001b[36m\u001b[1m2\u001b(B\u001b[m\u001b[2m modelrefs\u001b[1m)\u001b(B\u001b[m\u001b[2m via cli\r\n\u001b(B\u001b[m"]
