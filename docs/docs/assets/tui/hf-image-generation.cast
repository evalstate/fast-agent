[9.896348, "o", "\u001b[2mUse \u001b[32m'/'\u001b[39m for commands, \u001b[32m'!'\u001b[39m for shell. \u001b[32m'#'\u001b[39m to query, \u001b[32m'@'\u001b[39m to switch agents\r\nCTRL+T multiline, CTRL+Y copy last message, CTRL+E external editor.\r\nCTRL+Space or Tab for path completion. Use \u001b[35m/\u001b[95mattach\u001b[39m, `^file:`, `^url:`, or \u001b[33mCtrl+Alt+V\u001b[39m for attachments \u001b[1m(\u001b(B\u001b[m\u001b[2mexperimental\u001b[1m)\u001b(B\u001b[m\u001b[2m. F10\u001b[5;1Hto clear.\r\n\u001b(B\u001b[m"]
[9.896682, "o", "\u001b[2mModel shortcuts:\r\n\u001b(B\u001b[m"]
[9.897031, "o", "\u001b[2m  Shift+Tab = Service tier \u001b[1m(\u001b(B\u001b[m\u001b[2mstandard, fast\u001b[1m)\r\n\u001b(B\u001b[m"]
[9.897319, "o", "\u001b[2m  F6 = Reasoning \u001b[1m(\u001b(B\u001b[m\u001b[2mnone, low, medium, high, xhigh\u001b[1m)\r\n\u001b(B\u001b[m\u001b[2m  F7 = Verbosity \u001b[1m(\u001b(B\u001b[m\u001b[2mlow, medium, high\u001b[1m)\r\n\u001b(B\u001b[m"]
[9.89766, "o", "\u001b[2m  F8 = Web search \u001b[1m(\u001b(B\u001b[m\u001b[2mon, off\u001b[1m)\u001b[12;1H\u001b(B\u001b[m"]
