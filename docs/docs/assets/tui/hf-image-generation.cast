[11.129905, "o", "\u001b[2mUse \u001b[32m'/'\u001b[39m for commands, \u001b[32m'!'\u001b[39m for shell. \u001b[32m'#'\u001b[39m to query, \u001b[32m'@'\u001b[39m to switch agents\r\nCTRL+T multiline, CTRL+Y copy last message, CTRL+E external editor.\r\nCTRL+Space or Tab for path completion. Use \u001b[35m/\u001b[95mattach\u001b[39m, `^file:`, `^url:`, or \u001b[33mCtrl+Alt+V\u001b[39m for attachments \u001b[1m(\u001b(B\u001b[m\u001b[2mexperimental\u001b[1m)\u001b(B\u001b[m\u001b[2m. F10\u001b[4;1Hto clear.\r\n\u001b(B\u001b[m\u001b[2mModel shortcuts:\r\n\u001b(B\u001b[m"]
[11.130181, "o", "\u001b[2m  Shift+Tab = Service tier \u001b[1m(\u001b(B\u001b[m\u001b[2mstandard, fast\u001b[1m)\r\n\u001b(B\u001b[m"]
[11.130231, "o", "\u001b[2m  F6 = Reasoning \u001b[1m(\u001b(B\u001b[m\u001b[2mnone, low, medium, high, xhigh\u001b[1m)\r\n\u001b(B\u001b[m"]
[11.13072, "o", "\u001b[2m  F7 = Verbosity \u001b[1m(\u001b(B\u001b[m\u001b[2mlow, medium, high\u001b[1m)\r\n\u001b(B\u001b[m\u001b[2m  F8 = Web search \u001b[1m(\u001b(B\u001b[m\u001b[2mon, off\u001b[1m)\u001b[11;1H\u001b(B\u001b[m"]
[11.131318, "o", "\u001b[2mfast-agent environment\u001b(B\u001b[m \u001b[34m~/source/fast-agent-pr/.fast-agent\u001b[39m\u001b[2m \u001b[1m(\u001b[36m3\u001b(B\u001b[m\u001b[2m agents, \u001b[36m\u001b[1m4\u001b(B\u001b[m\u001b[2m hooks, \u001b[36m\u001b[1m3\u001b(B\u001b[m\u001b[2m extensions, \u001b[36m\u001b[1m2\u001b(B\u001b[m\u001b[2m modelrefs\u001b[1m)\u001b(B\u001b[m\u001b[2m via cli\r\n\u001b(B\u001b[m"]
[11.131411, "o", "\u001b[33m\u001b[1mAgents have shell\u001b(B\u001b[m\u001b[2m (skills, switch, sub-agent, bash | cwd: source/fast-agent-pr)\r\n\u001b(B\u001b[m"]
[11.318732, "o", "\u001b[2mAgent \u001b(B\u001b[m\u001b[34mdev\u001b[39m\u001b[2m:\u001b(B\u001b[m \u001b[36m\u001b[1m2\u001b(B\u001b[m\u001b[2m child agents. \u001b(B\u001b[m\u001b[36m\u001b[1m1\u001b(B\u001b[m\u001b[2m MCP Server \u001b[1m(\u001b(B\u001b[m\u001b[36m\u001b[1m27\u001b(B\u001b[m\u001b[2m tools, \u001b(B\u001b[m\u001b[36m\u001b[1m4\u001b(B\u001b[m\u001b[2m prompts, \u001b(B\u001b[m\u001b[36m\u001b[1m1\u001b(B\u001b[m\u001b[2m resource\u001b[1m)\u001b(B\u001b[m\u001b[2m. \u001b(B\u001b[m\u001b[36m\u001b[1m3\u001b(B\u001b[m\u001b[2m skills available\r\n\u001b(B\u001b[m"]
